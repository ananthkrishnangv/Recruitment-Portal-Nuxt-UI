# ═══════════════════════════════════════════════════
# CSIR-SERC Recruitment Portal — Environment Variables
# Copy to .env.local for development
# ═══════════════════════════════════════════════════

# ── Application ──
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_PORTAL_NAME="CSIR-SERC Recruitment Portal"

# ── Database (PostgreSQL) ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/csir_recruitment?schema=public"

# ── Redis ──
REDIS_URL="redis://localhost:6379"

# ── Security ──
SESSION_SECRET="dev-session-secret-change-in-production"
FIELD_ENCRYPTION_KEY="dev-encryption-key-32chars-ok!!!!"
ADMIN_BOOTSTRAP_PIN="123456"
DEMO_OTP="123456"

# ── File Storage ──
LOCAL_UPLOAD_DIR="storage/uploads"

# ── Telemetry ──
NEXT_TELEMETRY_DISABLED=1
