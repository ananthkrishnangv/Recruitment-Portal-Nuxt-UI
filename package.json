    "clsx": "latest",
    "effect": "^3.21.2",
    "framer-motion": "^12.40.0",
    "jose": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "pg": "^8.21.0",
    "react": "latest",
    "react-dom": "latest",
